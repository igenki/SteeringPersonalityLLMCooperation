{
    "model_settings": {
        "model_name": "gpt-3.5-turbo",
        "api_key": "",
        "provider": "openai",
        "reasoning_effort": "minimal",
        "verbosity": "low",
        "temperature": 0.7,
        "max_new_tokens": 2000
    },
    
    "experiment_settings": {
        "output_dir": "Re_BFI/results",
        "log_level": "INFO"
    },
    
    "re_bfi_settings": {
        "first_bfi_iterations": 0,
        "second_bfi_iterations": 1,
        "total_experiments": 1,
        "bfi_mode": "numbers_and_language",
        
        "use_existing_scores": true,
        "existing_scores_source": "Re_BFI/example_scores.json"
    },
    
    "analysis_settings": {
        "calculate_correlation": true,
        "calculate_mean_absolute_error": true,
        "save_detailed_results": true,
        "generate_plots": true
    },
    
    "_note": "このファイルは既存スコア機能をテストするための設定例です。example_scores.jsonのサンプルスコアを使用して、1回だけBFI測定を実行します。"
}
